{
  "rewrites": [
    { "source": "/dashboard", "destination": "/app/dashboard.html" },
    { "source": "/signin", "destination": "/app/signin.html" },
    { "source": "/signup", "destination": "/app/signup.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
